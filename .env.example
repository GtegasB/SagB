# Variáveis de ambiente (copie para .env.local)
# NUNCA commitar arquivos .env reais no Git

# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Proxy de IA no ambiente local (Vite dev server)
# Exemplo: https://sagb.piblo.com.br
VITE_AI_PROXY_TARGET=

# AI providers (server-side; used by Netlify Functions)
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
# Transcrição local (opcional, para ambiente 100% local)
# local_whisper = usa endpoint local OpenAI-compatible (/v1/audio/transcriptions)
# proxy (default) = usa /api/ai -> Netlify Function
VITE_TRANSCRIBE_PROVIDER=proxy
VITE_LOCAL_WHISPER_URL=
VITE_LOCAL_WHISPER_MODEL=whisper-1
VITE_LOCAL_WHISPER_LANGUAGE=pt
VITE_LOCAL_WHISPER_API_KEY=

# Compatibilidade temporaria (opcional):
# VITE_GEMINI_API_KEY=your-gemini-api-key
# VITE_DEEPSEEK_API_KEY=your-deepseek-api-key

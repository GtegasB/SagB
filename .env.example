# Variáveis de ambiente (copie para .env.local)
# NUNCA commitar arquivos .env reais no Git

# Supabase
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
# Proxy de IA no ambiente local (Vite dev server)
# Exemplo: https://sagb.piblo.com.br
VITE_AI_PROXY_TARGET=

# AI providers (server-side; used by Netlify Functions)
GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
QWEN_API_KEY=your-qwen-api-key
# Modelos opcionais (1 por provider)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
QWEN_MODEL=qwen-plus
# Endpoints opcionais
# OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions
# Llama local / Ollama (opcional)
# Ex.: http://127.0.0.1:11434
VITE_LOCAL_LLAMA_URL=
# Ex.: llama3.1:8b | qwen2.5:7b | mistral:7b
VITE_LOCAL_LLAMA_MODEL=llama3.1:8b
# Opcional para gateways OpenAI-compatible protegidos
VITE_LOCAL_LLAMA_API_KEY=
# Quando true, força chamada via /api/ai action=llama_local_chat
# (útil com Netlify Functions + LLAMA_LOCAL_URL no ambiente server-side)
VITE_LOCAL_LLAMA_USE_PROXY=false
# 0 = sem timeout no cliente; defina milissegundos se quiser limite local
VITE_LOCAL_LLAMA_TIMEOUT_MS=0
# Variáveis server-side alternativas (Netlify Function):
# LLAMA_LOCAL_URL=http://127.0.0.1:11434
# LLAMA_LOCAL_MODEL=llama3.1:8b
# LLAMA_LOCAL_API_KEY=
# Transcrição local (opcional, para ambiente 100% local)
# local_whisper = usa endpoint local OpenAI-compatible (/v1/audio/transcriptions)
# proxy (default) = usa /api/ai -> Netlify Function
VITE_TRANSCRIBE_PROVIDER=proxy
VITE_LOCAL_WHISPER_URL=
VITE_LOCAL_WHISPER_MODEL=whisper-1
VITE_LOCAL_WHISPER_LANGUAGE=pt
VITE_LOCAL_WHISPER_API_KEY=

# Compatibilidade temporaria (opcional):
# VITE_GEMINI_API_KEY=your-gemini-api-key
# VITE_DEEPSEEK_API_KEY=your-deepseek-api-key
